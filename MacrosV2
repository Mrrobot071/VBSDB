                    End If
                    
                    ' Nº NOTA FISCAL
                    Dim notaFiscalPat1 As String, notaFiscalPat2 As String
                    notaFiscalPat1 = "(?:N[º°o]?\s*(?:da\s*)?Nota\s*Fiscal|Nota\s*Fiscal|N[º°o]?\s*NF(?:-?e)?|NF-?e)\s*[:\-–—]?\s*(\d[\dA-Za-z\.\-\/]*)"
                    notaFiscalPat2 = "(?:N[º°o]?NOTAFISCAL|NOTAFISCAL|NF-?E)\s*[:\-–—]*\s*(\d[\dA-Za-z\.\-\/]*)"
                    
                    notaFiscal = RegexGetFirst(corpoLinhas, notaFiscalPat1)
